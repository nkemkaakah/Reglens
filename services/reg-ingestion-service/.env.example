# reg-ingestion-service — copy to `.env` in this directory for local `uvicorn` runs.
# cp .env.example .env

# Downstream obligation API (Spring)
OBLIGATION_SERVICE_BASE_URL=http://localhost:8080
# Optional: fixed Bearer token. If omitted/empty, a demo JWT is built per outbound call (same claims as frontend session.ts).
# OBLIGATION_SERVICE_TOKEN=

# LLM (API key only — model is fixed in app/core/config.py)
ANTHROPIC_API_KEY=

# Optional: emit one `document.ingested` event per successful ingest (workflow-service consumes).
# Leave empty for local runs without Kafka.
# KAFKA_BOOTSTRAP_SERVERS=localhost:9094
# KAFKA_TOPIC_DOCUMENT_INGESTED=document.ingested
