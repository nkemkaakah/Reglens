# RegLens — local environment (copy to `.env` in this folder: `cp .env.example .env`)
#
# Docker Compose loads `.env` from the directory you run `docker compose` in.
# From repo root: docker compose -f infra/docker-compose.yml up -d

# Ingestion service → LLM (passed through compose to `reg-ingestion-service`)
LLM_API_KEY=
