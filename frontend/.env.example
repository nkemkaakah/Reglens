# Copy to `.env` in this folder for local overrides (Vite reads `frontend/.env`).

# Optional: raw token only (no "Bearer " prefix). Defaults to dev-service-token-change-me — must match
# APP_SECURITY_SERVICE_TOKEN / OBLIGATION_SERVICE_TOKEN in infra/docker-compose.yml.
# VITE_REGLENS_SERVICE_TOKEN=dev-service-token-change-me

# mapping-service (Feature 4 — suggest / approve mappings). Default http://localhost:3000
# VITE_MAPPING_API_URL=http://localhost:3000

# Reviewer name for accepting mappings and recording rejections (obligation rows + Kafka + audit).
# VITE_REGLENS_APPROVER=your-name
